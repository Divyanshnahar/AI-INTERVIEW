generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  name       String?
  interviews Interview[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Interview {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Context for the AI
  jobTitle         String
  jobDescription   String          @db.Text
  resumeText       String          @db.Text
  
  // State and Analytics
  status           InterviewStatus @default(IN_PROGRESS)
  categoryScores   Json?           // e.g., { "Java": 80, "React": 60, "System Design": 90 }
  overallScore     Int?
  finalFeedback    String?         @db.Text
  
  transcripts      Transcript[]
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Transcript {
  id           String    @id @default(uuid())
  interviewId  String
  interview    Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  
  role         Role      // Indicates if the AI or the Student is speaking
  content      String    @db.Text
  
  // Metadata for the AI's reasoning
  isFollowUp   Boolean   @default(false)
  aiEvaluation String?   @db.Text // Hidden from user initially: AI's internal note on why the user's answer was good/bad
  
  createdAt    DateTime  @default(now())
}

enum Role {
  AI
  STUDENT
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
